# ============================================
# 智慧矿山安全监测平台 - 环境配置
# ============================================

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_mine_monitoring
DB_USER=postgres
DB_PASSWORD=postgres

# 服务端口
SERVER_PORT=3000

# Node环境
NODE_ENV=production

# 传感器模拟器配置
WS_URL=ws://localhost:3000
SIMULATION_INTERVAL=10000
ANOMALY_RATE=0.05

# 人员定位模拟器配置
UPDATE_INTERVAL=2000

# TimescaleDB配置
TIMESCALEDB_CHUNK_TIME_INTERVAL=1 hour
TIMESCALEDB_RETENTION_PERIOD=30 days
TIMESCALEDB_COMPRESSION_THRESHOLD=7 days
